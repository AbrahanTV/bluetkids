SECRET_KEY=change-this-to-a-random-string

# MySQL — set the password you chose when installing MySQL Community Server
DATABASE_URL=mysql+pymysql://root:your-password@localhost/bluetkids

# Gmail SMTP — use an App Password, not your real password
# https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Where enrollment notifications are sent
CENTER_EMAIL=center-inbox@gmail.com
